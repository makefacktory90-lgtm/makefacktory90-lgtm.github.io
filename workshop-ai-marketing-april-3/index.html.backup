<!-- ФИНАЛ -->
<section style="background:#fafafa">
  <div class="container">
    <h2 class="display" style="font-size:clamp(32px,5vw,72px);margin-bottom:32px">
      ДОМАШНЕЕ ЗАДАНИЕ
    </h2>
    <div class="step-card" style="background:#fff">
      <div class="step-num">1</div>
      <p class="step-text">Выберите 2 инструмента из 9 – ваш стек</p>
