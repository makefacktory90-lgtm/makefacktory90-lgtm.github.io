<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>AI для маркетинга — Корпоративный воркшоп 3 апреля 2026</title>
<style>
/* ── RESET ─────────────────────────────────── */
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:#fff;color:#111;font-family:Impact,Arial Black,sans-serif;overflow-x:hidden;line-height:1.5}

/* ── VARIABLES ─────────────────────────────── */
:root{
  --red:#E63946;
  --black:#111;
  --white:#fff;
  --gray:#E5E5E5;
  --mid:#888;
}

/* ── TYPOGRAPHY ────────────────────────────── */
.display{font-family:Impact,"Arial Black",sans-serif;text-transform:uppercase;letter-spacing:.02em}
.serif{font-family:Georgia,"Times New Roman",serif}
.kicker{font-size:11px;letter-spacing:.26em;text-transform:uppercase;color:var(--mid)}

/* ── LAYOUT ────────────────────────────────── */
section{border-bottom:1px solid var(--gray);padding:64px 64px;position:relative;overflow:hidden}
.container{max-width:1100px;margin:0 auto}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}

/* ── SPINE ─────────────────────────────────── */
#spine-track{position:fixed;top:0;left:0;width:3px;height:100%;background:var(--gray);z-index:99}
#spine-fill{width:100%;background:var(--red);height:0%;transition:height .1s linear}
#prog-bar{position:fixed;top:0;left:3px;right:0;height:2px;background:var(--gray);z-index:98}
#prog-fill{height:100%;width:0%;background:var(--red);transition:width .1s linear}

/* ── OUTLINE BG TEXT ───────────────────────── */
.bg-word{
  position:absolute;
  font-family:Impact,"Arial Black",sans-serif;
  text-transform:uppercase;
  -webkit-text-stroke:1px #E5E5E5;
  color:transparent;
  pointer-events:none;
  user-select:none;
  line-height:.88;
}

/* ── RED LINE ──────────────────────────────── */
.red-line{width:60px;height:3px;background:var(--red);display:block;margin:20px 0}

/* ── CARDS ───────────────────────────────── */
.level-card{
  border:1px solid var(--gray);
  padding:24px;
  margin-bottom:16px;
  cursor:default;
  transition:background .22s,color .22s,border-color .22s;
}
.level-card:hover{background:var(--red);color:#fff;border-color:var(--red)}
.level-card:hover .kicker{color:rgba(255,255,255,.65)}
.level-card:hover p{color:rgba(255,255,255,.85)}

.level-num{
  font-family:Impact,"Arial Black",sans-serif;
  font-size:48px;
  color:var(--red);
  line-height:1;
  margin-bottom:8px;
}
.level-card:hover .level-num{color:#fff}

.level-title{
  font-family:Impact,"Arial Black",sans-serif;
  font-size:22px;
  text-transform:uppercase;
  margin-bottom:12px;
}

.level-desc{
  font-family:Arial,sans-serif;
  font-size:15px;
  line-height:1.6;
  color:#555;
}

/* ── PROMPT ACCORDION ─────────────────────────────── */
.prompt-trigger{
  width:100%;display:flex;justify-content:space-between;align-items:center;
  padding:20px 24px;text-align:left;background:#fafafa;
  border-bottom:1px solid var(--gray);cursor:pointer;
  border:1px solid var(--gray);
  margin-top:20px;
}
.prompt-trigger:hover{background:#f0f0f0}
.plus{font-size:32px;color:var(--red);font-family:Arial,sans-serif;transition:transform .3s}
.prompt-trigger.open .plus{transform:rotate(45deg)}
.prompt-body{
  max-height:0;overflow:hidden;transition:max-height .55s cubic-bezier(.16,1,.3,1);
  border:1px solid var(--gray);border-top:none;
}
.prompt-body.open{max-height:4000px}
.prompt-content{
  padding:24px;
  background:#f9f9f9;
  font-family:'Courier New',monospace;
  font-size:13px;
  line-height:1.7;
  white-space:pre-wrap;
  color:#222;
}

/* ── STEP CARDS ───────────────────────────────── */
.step-card{
  background:#fafafa;
  border:1px solid var(--gray);
  padding:20px;
  margin-bottom:12px;
}
.step-num{
  font-family:Impact,"Arial Black",sans-serif;
  font-size:32px;
  color:var(--red);
  margin-bottom:8px;
}
.step-text{
  font-family:Arial,sans-serif;
  font-size:15px;
  line-height:1.6;
}

/* ── LINKS ─────────────────────────────────── */
.red-btn{
  display:inline-flex;align-items:center;gap:8px;
  border:1px solid var(--red);color:var(--red);
  padding:12px 20px;font-size:12px;letter-spacing:.18em;
  text-transform:uppercase;text-decoration:none;
  transition:background .2s,color .2s;font-family:Arial,sans-serif;
}
.red-btn:hover{background:var(--red);color:#fff}

/* ── GRAIN OVERLAY ─────────────────────────── */
#grain-overlay{
  position:fixed;inset:0;width:100%;height:100%;
  pointer-events:none;z-index:9996;
  opacity:.055;mix-blend-mode:overlay;
  animation:grainShift .12s steps(1) infinite;
  background-size:200px 200px;
}
@keyframes grainShift{
  0%{transform:translate(0,0)}
  16%{transform:translate(-3px,-4px)}
  33%{transform:translate(4px,2px)}
  50%{transform:translate(-2px,3px)}
  66%{transform:translate(3px,-2px)}
  83%{transform:translate(-4px,3px)}
  100%{transform:translate(0,0)}
}

/* ── SCANLINE ─────────────────────────────── */
#scanline{
  position:fixed;top:-2px;left:0;right:0;height:1px;
  background:var(--red);opacity:.55;z-index:9999;
  pointer-events:none;will-change:top;
}

@media(max-width:860px){
  section{padding:40px 20px}
  .grid-2,.grid-3{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- SCANLINE -->
<div id="scanline"></div>

<!-- GRAIN OVERLAY -->
<div id="grain-overlay"></div>

<!-- SPINE -->
<div id="spine-track"><div id="spine-fill"></div></div>
<div id="prog-bar"><div id="prog-fill"></div></div>

<!-- ══════════════════════════════════════════
     HERO
══════════════════════════════════════════ -->
<section style="min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding-bottom:64px;border-bottom:1px solid var(--gray)">
  <span class="bg-word" style="font-size:clamp(100px,18vw,280px);top:10px;right:-10px;opacity:.3">ДЕЙСТВУЙ</span>

  <div class="container">
    <p class="kicker" style="margin-bottom:20px">КОРПОРАТИВНЫЙ ВОРКШОП / 3 АПРЕЛЯ 2026</p>

    <h1 class="display" style="font-size:clamp(42px,7.5vw,110px);line-height:.9;max-width:960px;margin-bottom:24px">
      AI ДЛЯ <span style="color:var(--red)">МАРКЕТИНГА</span>
    </h1>

    <span class="red-line"></span>

    <p class="serif" style="font-size:clamp(18px,2.5vw,26px);color:#444;max-width:560px;line-height:1.5">
      4 часа практики на реальных задачах вашей команды
    </p>
  </div>
</section>

<!-- ══════════════════════════════════════════
     ШОК: ЧТО РЕАЛЬНО ПРОИСХОДИТ
══════════════════════════════════════════ -->
<section style="min-height:80vh;display:flex;align-items:center">
  <span class="bg-word" style="font-size:clamp(80px,13vw,200px);bottom:-20px;left:-10px;opacity:.18">УРОВНИ</span>

  <div class="container">
    <p class="kicker" style="margin-bottom:16px">ЧТО РЕАЛЬНО ПРОИСХОДИТ</p>

    <h2 class="display" style="font-size:clamp(32px,5vw,72px);margin-bottom:32px">
      ТРИ УРОВНЯ AI-НАТИВНЫХ КОМПАНИЙ
    </h2>

    <div class="level-card">
      <div class="level-num">1</div>
      <div class="level-title">ОПТИМИЗАЦИЯ КОСТОВ</div>
      <p class="level-desc">
        Агенты заменяют рутину: код, договоры, поддержка, дизайн, бухгалтерия, маркетинг.<br><br>
        <strong>300 сотрудников × 10 процессов × 10 мин × 30 раз/мес = $470K экономии в месяц</strong>
      </p>
    </div>

    <div class="level-card">
      <div class="level-num">2</div>
      <div class="level-title">МАСШТАБИРОВАНИЕ БИЗНЕСА</div>
      <p class="level-desc">
        Из новых возможностей построить или выйти на новый рынок.<br><br>
        Автономный агент-локализатор переводит продукт, адаптирует маркетинг, отвечает саппорту на 15 языках. Консалтинговая компания, которая раньше только давала рекомендации, теперь может и внедрять. Вместо одного продукта для всех, ваш продукт может гиперперсонализироваться на лету под каждого.
      </p>
    </div>

    <div class="level-card">
      <div class="level-num">3</div>
      <div class="level-title">CYBERNETIC OS</div>
      <p class="level-desc">
        Вы создаете автоматизированную систему по постоянному улучшению себя.<br><br>
        AI является менеджером для всей компании, а информационная обратная связь помогает ставить цели, вокруг которых организуются агенты (для любой «понятной» работы) и люди (для нового, рискованного или требующего эмпатии и взаимоотношений).
      </p>
    </div>

    <div style="border-left:3px solid var(--red);padding-left:24px;max-width:780px;margin-top:32px">
      <p style="font-family:Impact,'Arial Black',sans-serif;font-size:22px;text-transform:uppercase;color:var(--red)">
        ВОПРОС: НА КАКОМ УРОВНЕ В��ШИ КОНКУРЕНТЫ?
      </p>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     СЕГОДНЯ НЕ ПРО "AI — ЭТО ХОРОШО"
══════════════════════════════════════════ -->
<section>
  <div class="container">
    <h2 class="display" style="font-size:clamp(32px,5vw,72px);margin-bottom:32px">
      СЕГОДНЯ НЕ ПРО<br>"AI — ЭТО ХОРОШО"
    </h2>

    <p class="serif" style="font-size:20px;line-height:1.65;max-width:700px;color:#444;margin-bottom:24px">
      Это и так понятно.
    </p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:28px">
      <div style="border:1px solid var(--gray);padding:20px">
        <p style="font-family:Arial,sans-serif;font-size:15px;line-height:1.6">
          <strong>Что уже возможно</strong><br>прямо сейчас
        </p>
      </div>
      <div style="border:1px solid var(--gray);padding:20px">
        <p style="font-family:Arial,sans-serif;font-size:15px;line-height:1.6">
          <strong>Как делать документы</strong><br>не руками
        </p>
      </div>
      <div style="border:1px solid var(--gray);padding:20px">
        <p style="font-family:Arial,sans-serif;font-size:15px;line-height:1.6">
          <strong>Главное — понять,</strong><br>что это существует
        </p>
      </div>
    </div>
  </div>
</section>

<!-- QUICK WIN: NOTEBOOKLM -->
<section style="background:#0a0a0a;color:#fff">
  <div class="container">
    <p class="kicker" style="margin-bottom:16px;color:#888">ПРЯМО СЕЙЧАС</p>
    <h2 class="display" style="font-size:clamp(32px,5vw,72px);margin-bottom:32px;color:#fff">
      КАК ВЫ ДЕЛАЕТЕ<br>ПРЕЗЕНТАЦИИ?<br><span style="color:var(--red)">РУКАМИ?</span>
    </h2>
    <p class="serif" style="font-size:20px;line-height:1.65;max-width:700px;color:#ccc;margin-bottom:32px">
      NotebookLM: Документ → презентация за 3 минуты
    </p>
    <div class="step-card" style="background:#1a1a1a;border-color:#333">
      <div class="step-num">1</div>
      <p class="step-text" style="color:#ccc">Откройте <strong style="color:#fff">notebooklm.google.com</strong></p>
    </div>
    <div class="step-card" style="background:#1a1a1a;border-color:#333">
      <div class="step-num">2</div>
      <p class="step-text" style="color:#ccc">Загрузите документ (PDF/Word/ссылка)</p>
    </div>
    <div class="step-card" style="background:#1a1a1a;border-color:#333">
      <div class="step-num">3</div>
      <p class="step-text" style="color:#ccc">Studio Panel → Slide Deck → Detailed Deck</p>
    </div>
    <div class="step-card" style="background:#1a1a1a;border-color:#333">
      <div class="step-num">4</div>
      <p class="step-text" style="color:#ccc">Вставьте промпт (ниже)</p>
    </div>
    <button class="prompt-trigger" onclick="togglePrompt('prompt-notebooklm')" style="background:#1a1a1a;border-color:#333;color:#fff">
      <span style="font-family:Impact,'Arial Black',sans-serif;font-size:18px;text-transform:uppercase;letter-spacing:.1em">ПРОМПТ ДЛЯ NOTEBOOKLM</span>
      <span class="plus">+</span>
    </button>
    <div class="prompt-body" id="prompt-notebooklm">
      <div class="prompt-content" style="background:#0a0a0a;color:#00ff41">Роль: дизайнер презентаций McKinsey.
Аудитория: руководители отделов маркетинга

Для каждого слайда:
— Заголовок = вывод. Не "Продажи Q4", а "Продажи Q4 выросли на 47% год к году"
— Максимум 3 тезиса, каждый ≤ 12 слов
— Каждый тезис = факт из источника с цитатой

Первый слайд: самый удивительный инсайт из материала.
  Тот, ради которого стоит смотреть дальше.
Предпоследний: сравнение "было → стало"
Последний: одно действие. Не "Спасибо"

Формат: Detailed Deck
Стиль: минималистичный, много воздуха
Язык: русский</div>
    </div>
    <p style="font-family:Impact,'Arial Black',sans-serif;font-size:28px;text-transform:uppercase;color:var(--red);margin-top:40px;text-align:center">
      У КОГО ПОЛУЧИЛОСЬ? 🙋
    </p>
  </div>
</section>

<!-- ВАШУ КОМАНДУ ИЗУЧИЛИ -->
<section>
  <div class="container">
    <p class="kicker" style="margin-bottom:16px">ВАШУ КОМАНДУ ИЗУЧИЛИ</p>
    <h2 class="display" style="font-size:clamp(32px,5vw,72px);margin-bottom:32px">
      19 АНКЕТ. 4 БАРЬЕРА.<br>ПРОГРАММА ЗАКРЫВАЕТ КАЖДЫЙ.
    </h2>
    <div class="grid-2" style="gap:20px">
      <div style="border:1px solid var(--gray);padding:24px">
        <p style="font-family:Impact,'Arial Black',sans-serif;font-size:48px;color:var(--red);margin-bottom:8px">63%</p>
        <p style="font-family:Arial,sans-serif;font-size:16px;margin-bottom:8px"><strong>Не знаю, какой инструмент</strong></p>
        <p style="font-family:Arial,sans-serif;font-size:14px;color:#666">Дадим стек из 3 — не 20</p>
      </div>
      <div style="border:1px solid var(--gray);padding:24px">
        <p style="font-family:Impact,'Arial Black',sans-serif;font-size:48px;color:var(--red);margin-bottom:8px">47%</p>
        <p style="font-family:Arial,sans-serif;font-size:16px;margin-bottom:8px"><strong>Не умею формулировать</strong></p>
        <p style="font-family:Arial,sans-serif;font-size:14px;color:#666">Промпт как мышление, не формула</p>
      </div>
      <div style="border:1px solid var(--gray);padding:24px">
        <p style="font-family:Impact,'Arial Black',sans-serif;font-size:48px;color:var(--red);margin-bottom:8px">42%</p>
        <p style="font-family:Arial,sans-serif;font-size:16px;margin-bottom:8px"><strong>Нет времени разбираться</strong></p>
        <p style="font-family:Arial,sans-serif;font-size:14px;color:#666">4 часа → готовый набор навыков</p>
      </div>
      <div style="border:1px solid var(--gray);padding:24px">
        <p style="font-family:Impact,'Arial Black',sans-serif;font-size:48px;color:var(--red);margin-bottom:8px">26%</p>
        <p style="font-family:Arial,sans-serif;font-size:16px;margin-bottom:8px"><strong>Не доверяю результатам</strong></p>
        <p style="font-family:Arial,sans-serif;font-size:14px;color:#666">Perplexity: источники, верификация</p>
      </div>
    </div>
  </div>
</section>

<!-- МАРШРУТ -->
<section style="background:#fafafa">
  <div class="container">
    <p class="kicker" style="margin-bottom:16px">МАРШРУТ</p>
    <h2 class="display" style="font-size:clamp(32px,5vw,72px);margin-bottom:32px">
      ОТ НУЛЯ ДО НАВЫКА<br>ЗА 4 ЧАСА
    </h2>
    <div style="display:grid;gap:12px">
      <div style="display:flex;align-items:center;gap:16px;border:1px solid var(--gray);padding:16px;background:#fff">
        <span style="font-family:Impact,'Arial Black',sans-serif;font-size:32px;color:var(--red);min-width:50px">1</span>
        <div style="flex:1">
          <p style="font-family:Impact,'Arial Black',sans-serif;font-size:18px;text-transform:uppercase">ПРЕЗЕНТАЦИИ</p>
          <p style="font-family:Arial,sans-serif;font-size:14px;color:#666">Gamma, Kimi, Live Demo</p>
        </div>
        <span style="font-family:Arial,sans-serif;font-size:14px;color:#888">40 мин</span>
      </div>
      <div style="display:flex;align-items:center;gap:16px;border:1px solid var(--gray);padding:16px;background:#fff">
        <span style="font-family:Impact,'Arial Black',sans-serif;font-size:32px;color:var(--red);min-width:50px">2</span>
        <div style="flex:1">
          <p style="font-family:Impact,'Arial Black',sans-serif;font-size:18px;text-transform:uppercase">ТЕКСТЫ</p>
          <p style="font-family:Arial,sans-serif;font-size:14px;color:#666">ToV-карта, адаптация, промпты</p>
        </div>
        <span style="font-family:Arial,sans-serif;font-size:14px;color:#888">50 мин</span>
      </div>
      <div style="display:flex;align-items:center;gap:16px;border:1px solid var(--gray);padding:16px;background:#fff">
        <span style="font-family:Impact,'Arial Black',sans-serif;font-size:32px;color:var(--red);min-width:50px">3</span>
        <div style="flex:1">
          <p style="font-family:Impact,'Arial Black',sans-serif;font-size:18px;text-transform:uppercase">РЕСЁРЧ</p>
          <p style="font-family:Arial,sans-serif;font-size:14px;color:#666">Perplexity, тренды, фактчекинг</p>
        </div>
        <span style="font-family:Arial,sans-serif;font-size:14px;color:#888">30 мин</span>
      </div>
      <div style="display:flex;align-items:center;gap:16px;border:1px solid var(--gray);padding:16px;background:#fff">
        <span style="font-family:Impact,'Arial Black',sans-serif;font-size:32px;color:var(--red);min-width:50px">4</span>
        <div style="flex:1">
          <p style="font-family:Impact,'Arial Black',sans-serif;font-size:18px;text-transform:uppercase">ВИЗУАЛ + ВИДЕО</p>
          <p style="font-family:Arial,sans-serif;font-size:14px;color:#666">Gemini, Higgsfield, Chronicle</p>
        </div>
        <span style="font-family:Arial,sans-serif;font-size:14px;color:#888">30 мин</span>
      </div>
      <div style="display:flex;align-items:center;gap:16px;border:1px solid var(--gray);padding:16px;background:#fff">
        <span style="font-family:Impact,'Arial Black',sans-serif;font-size:32px;color:var(--red);min-width:50px">5</span>
        <div style="flex:1">
          <p style="font-family:Impact,'Arial Black',sans-serif;font-size:18px;text-transform:uppercase">БОНУС</p>
          <p style="font-family:Arial,sans-serif;font-size:14px;color:#666">Cowork, автоматизация</p>
        </div>
        <span style="font-family:Arial,sans-serif;font-size:14px;color:#888">20 мин</span>
      </div>
    </div>
  </div>
</section>

<!-- БЛОК 1: ПРЕЗЕНТАЦИИ -->
<section style="background:#0a0a0a;color:#fff;min-height:60vh;display:flex;align-items:center">
  <div class="container">
    <p class="kicker" style="color:#888;margin-bottom:16px">БЛОК 1 / 40 МИНУТ</p>
    <h2 class="display" style="font-size:clamp(42px,7vw,110px);color:#fff;margin-bottom:20px">
      ПРЕЗЕНТАЦИИ
    </h2>
    <p class="serif" style="font-size:22px;color:#ccc;max-width:600px">
      Запрос №1 из анкет: 14 из 19 человек
    </p>
  </div>
</section>

<!-- УПРАЖНЕНИЕ: KIMI -->
<section>
  <div class="container">
    <p class="kicker" style="margin-bottom:16px">УПРАЖНЕНИЕ 1 / 15 МИНУТ</p>
