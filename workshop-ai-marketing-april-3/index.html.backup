        ДЕДЛАЙН: ПЯТНИЦА 5 АПРЕЛЯ
      </p>
    </div>
  </div>
</section>

<script>
// Промпт аккордеоны
function togglePrompt(id) {
  const triggers = document.querySelectorAll('.prompt-trigger');
  const bodies = document.querySelectorAll('.prompt-body');
  
  triggers.forEach((t, i) => {
    const body = bodies[i];
    const targetBody = document.getElementById(id);
    
    if (body === targetBody) {
      const isOpen = t.classList.contains('open');
      t.classList.toggle('open');
      body.classList.toggle('open');
    }
  });
}

// Прогресс скролла
window.addEventListener('scroll', () => {
  const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
  const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
  const scrolled = (winScroll / height) * 100;
  document.getElementById('spine-fill').style.height = scrolled + '%';
  document.getElementById('prog-fill').style.width = scrolled + '%';
});

// Сканлайн анимация
const scanline = document.getElementById('scanline');
let scanPos = 0;
setInterval(() => {
  scanPos = (scanPos + 2) % window.innerHeight;
  scanline.style.top = scanPos + 'px';
}, 16);
</script>

</body>
</html>
